{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "esnext", // ✅ ESM
    "moduleResolution": "bundler",
    "target": "esnext",
    "types": ["node"],
    "typeRoots": ["./src/types", "./node_modules/@types"], // ✅ add this
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
